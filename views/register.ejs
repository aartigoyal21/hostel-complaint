<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register Complaint</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

nav{
    background:#2c3e50;
    padding:15px 50px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav h2{
    color:white;
}

nav a{
    text-decoration:none;
    color:white;
    font-weight:bold;
}

nav a:hover{
    color:#f39c12;
}

.register-section{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#f4f6f7;
    padding:40px;
}

.form-box{
    background:white;
    padding:40px;
    width:100%;
    max-width:500px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
    border-radius:10px;
}

.form-box h2{
    text-align:center;
    margin-bottom:25px;
    color:#2c3e50;
}

.form-group{
    margin-bottom:20px;
}

.form-group label{
    display:block;
    margin-bottom:6px;
    font-weight:bold;
}

.form-group input,
.form-group select,
.form-group textarea{
    width:100%;
    padding:10px;
    border:1px solid #ccc;
    border-radius:5px;
    font-size:14px;
}

.form-group textarea{
    resize:none;
    height:100px;
}

button{
    width:100%;
    padding:12px;
    background:#f39c12;
    border:none;
    color:white;
    font-size:16px;
    border-radius:6px;
    cursor:pointer;
}

button:hover{
    background:#d68910;
}
</style>
</head>

<body>

<nav>
    <h2>HostelCare</h2>
    <a href="/">Back to Home</a>
</nav>


<section class="register-section">
<div class="form-box">
    <h2>Register Complaint</h2>

    <form action="/submit-complaint" method="POST">

        <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" required>
        </div>

        <div class="form-group">
            <label>Room Number</label>
            <input type="text" name="room" required>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" required>
        </div>

        <div class="form-group">
            <label>Complaint Category</label>
            <select name="category" required>
                <option value="">Select Category</option>
                <option>Electricity</option>
                <option>Water</option>
                <option>Mess</option>
                <option>Cleanliness</option>
            </select>
        </div>

        <div class="form-group">
            <label>Complaint Description</label>
            <textarea name="description" required></textarea>
        </div>

        <button type="submit">Submit Complaint</button>

    </form>
</div>
</section>

</body>
</html>