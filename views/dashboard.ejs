<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | HostelCare</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="logo">HostelCare</div>
    <nav class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/complaint/new">Raise Complaint</a>
      <a href="/complaints/my">My Complaints</a>
      <a href="/admin/dashboard">Admin</a>
      <a href="/logout">Logout</a>
    </nav>
  </header>

 
  <section class="features-section" style="padding-bottom: 10px;">
    <div class="feature-card" style="max-width: 420px; margin: 0 auto; text-align: center;">
      
      <% if (user && user.profilePic) { %>
        <img 
          src="<%= user.profilePic %>" 
          alt="Profile Picture"
          style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: 15px; border: 4px solid #e9d5ff;"
        />
      <% } else { %>
        <div style="width:120px; height:120px; border-radius:50%; background:#ede9fe; margin:0 auto 15px; display:flex; align-items:center; justify-content:center; font-size:36px; font-weight:700; color:#7c3aed;">
          <%= user && user.name ? user.name.charAt(0).toUpperCase() : "S" %>
        </div>
      <% } %>

      <h3>Welcome, <%= user && user.name ? user.name : "Student" %></h3>
      <p>Your student dashboard is ready.</p>
    </div>
  </section>


  <section class="hero" style="padding-top:20px;">
    <div class="hero-text-box">
      <span class="badge">Student Panel</span>
      <h1>Welcome back, <span><%= user && user.name ? user.name : "Student" %></span></h1>
      <p>
        Manage your hostel issues from one clean dashboard. Raise a complaint,
        track progress, and stay updated with admin actions.
      </p>

      <div class="hero-buttons">
        <a href="/complaint/new" class="btn primary-btn">Raise Complaint</a>
        <a href="/complaints/my" class="btn secondary-btn">View My Complaints</a>
      </div>
    </div>

    <div class="hero-card">
      <h2>Quick Summary</h2>
      <ul>
        <li>Total Complaints: 8</li>
        <li>Pending: 3</li>
        <li>In Progress: 2</li>
        <li>Resolved: 3</li>
      </ul>
    </div>
  </section>


  <section class="features-section">
    <h2>Complaint Overview</h2>
    <div class="feature-grid">
      <div class="feature-card">
        <h3>Total Complaints</h3>
        <p>08</p>
      </div>
      <div class="feature-card">
        <h3>Pending</h3>
        <p>03</p>
      </div>
      <div class="feature-card">
        <h3>In Progress</h3>
        <p>02</p>
      </div>
      <div class="feature-card">
        <h3>Resolved</h3>
        <p>03</p>
      </div>
    </div>
  </section>


  <section class="features-section" style="padding-top:0;">
    <h2>Recent Activity</h2>
    <div class="feature-grid">
      <div class="feature-card">
        <h3>Water Leakage</h3>
        <p>Status: Pending</p>
      </div>
      <div class="feature-card">
        <h3>WiFi Issue</h3>
        <p>Status: In Progress</p>
      </div>
      <div class="feature-card">
        <h3>Fan Repair</h3>
        <p>Status: Resolved</p>
      </div>
      <div class="feature-card">
        <h3>Bathroom Cleaning</h3>
        <p>Status: Pending</p>
      </div>
    </div>
  </section>

</body>
</html>
