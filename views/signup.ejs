<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signup | HostelCare</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="form-page">
  <div class="form-wrapper">
    <div class="form-left">
      <a href="/" class="back-link">← Back to Home</a>
      <span class="badge">Create Account</span>
      <h1>Join <span>HostelCare</span></h1>
      <p>
        Register yourself to submit hostel complaints and track updates.
      </p>
    </div>

    <div class="form-card-box signup-box">
      <h2>Sign Up</h2>
      <form action="/signup" method="POST" enctype="multipart/form-data">
        <div class="input-box">
          <label>Full Name</label>
          <input type="text" name="name" placeholder="Enter your full name" required />
        </div>

        <div class="input-box">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="Enter your email" required />
        </div>

        <div class="input-box">
          <label>Password</label>
          <input type="password" name="password" placeholder="Create password" required />
        </div>

        <div class="input-box">
          <label>Hostel Block</label>
          <input type="text" name="hostelBlock" placeholder="Enter hostel block" required />
        </div>

        <div class="input-box">
          <label>Room Number</label>
          <input type="text" name="roomNo" placeholder="Enter room number" required />
        </div>

        <div class="input-box">
          <label>Profile Picture</label>
          <input type="file" name="profilePic" accept="image/*" />
        </div>

        <button type="submit" class="submit-btn">Create Account</button>
      </form>

      <p class="bottom-text">
        Already have an account? <a href="/login">Login</a>
      </p>
    </div>
  </div>
</body>
</html>
