<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HostelCare | Home</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="navbar">
    <div class="logo">HostelCare</div>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="#features">Features</a>
      <a href="#working">How It Works</a>
      <a href="/login">Login</a>
      <a href="/signup" class="nav-btn">Sign Up</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-text-box">
      <span class="badge">Hostel Complaint Portal</span>
      <h1>Simple way to manage <span>hostel complaints</span></h1>
      <p>
        HostelCare helps students submit complaints online and lets admins manage
        them easily from one place. It makes the complaint process clear, fast,
        and easier for both students and hostel staff.
      </p>

      <div class="hero-buttons">
        <a href="/signup" class="btn primary-btn">Create Account</a>
        <a href="/login" class="btn secondary-btn">Login</a>
      </div>
    </div>

    <div class="hero-card">
      <h2>What you can do</h2>
      <ul>
        <li>Register student account</li>
        <li>Login securely</li>
        <li>Submit hostel complaints</li>
        <li>Track complaint status</li>
        <li>Manage profile details</li>
        <li>Admin can update complaint progress</li>
      </ul>
    </div>
  </section>

  <section class="features-section" id="features">
    <h2>Features</h2>
    

    <div class="feature-grid">
      <div class="feature-card">
        <h3>Student Registration</h3>
        <p>
          Students can create their account using personal and hostel details.
        </p>
      </div>

      <div class="feature-card">
        <h3>Secure Login</h3>
        <p>
          Login system allows users to access their dashboard safely.
        </p>
      </div>

      <div class="feature-card">
        <h3>Raise Complaint</h3>
        <p>
          Students can submit complaints related to room, electricity, water,
          cleanliness, or other hostel issues.
        </p>
      </div>

      <div class="feature-card">
        <h3>Complaint Status</h3>
        <p>
          Users can check whether their complaint is pending, in progress,
          or resolved.
        </p>
      </div>

      <div class="feature-card">
        <h3>Student Dashboard</h3>
        <p>
          A separate dashboard helps students view all submitted complaints in one place.
        </p>
      </div>

      <div class="feature-card">
        <h3>Admin Panel</h3>
        <p>
          Admin can view all complaints and update their current status easily.
        </p>
      </div>

      <div class="feature-card">
        <h3>Profile Management</h3>
        <p>
          Students can maintain profile information and upload profile picture.
        </p>
      </div>

      <div class="feature-card">
        <h3>Better Organization</h3>
        <p>
          All complaint records remain stored properly, reducing confusion and manual work.
        </p>
      </div>
    </div>
  </section>

  <section class="features-section" id="working">
    <h2>How It Works</h2>
    
    <div class="feature-grid">
      <div class="feature-card">
        <h3>1. Sign Up</h3>
        <p>
          Student first creates an account on the platform.
        </p>
      </div>

      <div class="feature-card">
        <h3>2. Login</h3>
        <p>
          After registration, the student logs in to access the dashboard.
        </p>
      </div>

      <div class="feature-card">
        <h3>3. Submit Complaint</h3>
        <p>
          Student enters complaint details and submits the issue online.
        </p>
      </div>

      <div class="feature-card">
        <h3>4. Admin Update</h3>
        <p>
          Admin checks the complaint and updates the status for the student.
        </p>
      </div>
    </div>
  </section>

  <section class="features-section">
    <h2>Why use HostelCare?</h2>

    <div class="feature-grid">
      <div class="feature-card">
        <h3>Less Manual Work</h3>
        <p>
          Students do not need to visit the office again and again to report issues.
        </p>
      </div>

      <div class="feature-card">
        <h3>Clear Communication</h3>
        <p>
          Complaint status remains visible, so students know the current progress.
        </p>
      </div>

      <div class="feature-card">
        <h3>Easy Management</h3>
        <p>
          Admin gets a proper list of complaints in one system instead of manual records.
        </p>
      </div>

      <div class="feature-card">
        <h3>Useful for College Project</h3>
        <p>
          This project shows authentication, dashboard, CRUD operations, and admin handling.
        </p>
      </div>
    </div>
  </section>

  <footer class="footer">
    <p>© 2026 HostelCare</p>
    <p>Hostel Complaint Management System</p>
  </footer>

</body>
</html>
